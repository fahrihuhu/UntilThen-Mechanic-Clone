  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ChatTrigger
  allSequences:
  - messages:
    - senderName: S
      isPlayer: 0
      message: 'Ri, kamu lagi di

        Kayutangan kan?'
    requirePlayerReply: 1
    choice1Text: Iya, kenapa?
    nextSequence1: 1
    choice2Text: Iya nih kamu kok tau?
    nextSequence2: 1
  - messages:
    - senderName: S
      isPlayer: 0
      message: 'Bisa ke deket air mancur bentar?

        Ada yang mau aku omongin...'
    requirePlayerReply: 1
    choice1Text: Okey, ini jalan kesana.
    nextSequence1: 2
    choice2Text: Tumben serius amat. Tunggu situ.
    nextSequence2: 2
  - messages:
    - senderName: S
      isPlayer: 0
      message: Hati-hati jalannya.
    requirePlayerReply: 0
    choice1Text: 
    nextSequence1: -1
    choice2Text: 
    nextSequence2: -1
