  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2e93609f660f06c4eb9ea8e9d80dce06, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InteractableObject
  dialogueLines:
  - characterName: Salma
    characterPortrait: {fileID: 0}
    sentence: '"Ri... makasih udah mau dateng."'
  - characterName: Fahri
    characterPortrait: {fileID: 0}
    sentence: '"Santai aja. Tumben ngajak ketemu di sini, ada apa?"'
  - characterName: Salma
    characterPortrait: {fileID: 0}
    sentence: '"Gak kerasa ya, udah mau tahun baru aja..."'
  - characterName: Salma
    characterPortrait: {fileID: 0}
    sentence: '"Aku cuma mau bilang... makasih buat semuanya selama ini."'
  - characterName: Salma
    characterPortrait: {fileID: 0}
    sentence: '"Makasih udah selalu nemenin, walau kadang kamu sibuk sendiri sama
      kegiatan kamu."'
  - characterName: Fahri
    characterPortrait: {fileID: 0}
    sentence: '"Makasih udah selalu nemenin, walau kadang kamu sibuk sendiri sama
      kegiatan kamu."'
  promptIcon: {fileID: 564064358}
